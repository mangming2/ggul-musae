#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/jiho/Documents/GitHub/ggul-musae/node_modules/.pnpm/uglify-es@3.3.9/node_modules/uglify-es/bin/node_modules:/Users/jiho/Documents/GitHub/ggul-musae/node_modules/.pnpm/uglify-es@3.3.9/node_modules/uglify-es/node_modules:/Users/jiho/Documents/GitHub/ggul-musae/node_modules/.pnpm/uglify-es@3.3.9/node_modules:/Users/jiho/Documents/GitHub/ggul-musae/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/jiho/Documents/GitHub/ggul-musae/node_modules/.pnpm/uglify-es@3.3.9/node_modules/uglify-es/bin/node_modules:/Users/jiho/Documents/GitHub/ggul-musae/node_modules/.pnpm/uglify-es@3.3.9/node_modules/uglify-es/node_modules:/Users/jiho/Documents/GitHub/ggul-musae/node_modules/.pnpm/uglify-es@3.3.9/node_modules:/Users/jiho/Documents/GitHub/ggul-musae/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../uglify-es@3.3.9/node_modules/uglify-es/bin/uglifyjs" "$@"
else
  exec node  "$basedir/../../../../../uglify-es@3.3.9/node_modules/uglify-es/bin/uglifyjs" "$@"
fi
